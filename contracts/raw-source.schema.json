{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://p-reinforce.local/contracts/raw-source.schema.json",
  "title": "RawSourceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "schema_version",
    "created_at",
    "source_type",
    "origin",
    "title",
    "sha256",
    "raw_root",
    "text_path",
    "attachments",
    "status"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^src_[0-9]{8}_[a-z0-9]{8,16}$"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "text",
        "image",
        "mixed",
        "article",
        "pdf",
        "audio",
        "video",
        "web_capture",
        "meeting_note",
        "chat_capture"
      ]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "captured_from"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "web_app",
            "local_agent",
            "mobile_capture",
            "import_script",
            "browser_clipper"
          ]
        },
        "captured_from": {
          "type": "string",
          "minLength": 1
        },
        "original_url": {
          "type": "string"
        },
        "imported_by": {
          "type": "string"
        },
        "device": {
          "type": "string"
        }
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "raw_root": {
      "type": "string",
      "pattern": "^00_Raw/.+"
    },
    "text_path": {
      "type": "string",
      "pattern": "^00_Raw/.+/(source\\.md|source\\.txt)$"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachment_id",
          "path",
          "mime_type",
          "sha256",
          "size_bytes"
        ],
        "properties": {
          "attachment_id": {
            "type": "string",
            "pattern": "^att_[a-z0-9]{6,16}$"
          },
          "path": {
            "type": "string",
            "pattern": "^00_Raw/.+/attachments/.+"
          },
          "mime_type": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "captured",
        "proposed",
        "applied",
        "archived",
        "error"
      ]
    }
  }
}
